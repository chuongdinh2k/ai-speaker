# Local .terraform directory
.terraform/

# Terraform lock file — commit this to pin provider versions
# .terraform.lock.hcl

# State files — stored in S3 remote backend
*.tfstate
*.tfstate.backup

# Crash log
crash.log
crash.*.log

# Sensitive variable files — never commit these
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
